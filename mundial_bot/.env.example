# ── Telegram ─────────────────────────────────────────────────────────────────
# 1. Crea un bot con @BotFather → te da el token
# 2. Manda un mensaje al bot y visita:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    → busca "chat":{"id":...} para obtener tu CHAT_ID
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=987654321

# ── Polling ───────────────────────────────────────────────────────────────────
# Intervalo en segundos entre comprobaciones de partidos en vivo
POLL_INTERVAL_SECONDS=45

# ── Ventanas horarias (hora local Europe/Madrid) ──────────────────────────────
# El resumen matutino se envía una vez dentro de esta ventana (hora aleatoria)
MORNING_HOUR_START=9
MORNING_HOUR_END=11

# El resumen vespertino se envía una vez dentro de esta ventana
EVENING_HOUR_START=21
EVENING_HOUR_END=23
